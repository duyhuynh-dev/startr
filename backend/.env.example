# VC × Startup Matching Platform - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vc_matcher

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# ⚠️ IMPORTANT: Change this to a secure random string in production!
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# OAUTH CONFIGURATION (Optional - add when ready)
# ============================================================================
# LinkedIn OAuth - Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Google OAuth - Get from: https://console.cloud.google.com/apis/credentials
# In Google Cloud Console, add Authorized redirect URIs for your backend, e.g.:
#   Web:  http://localhost:3000/callback/google  (or your frontend origin + /callback/google)
#   API:  http://localhost:8012/api/v1/auth/oauth/google/callback  (for mobile WebView / direct API)
#   On device: use your machine IP, e.g. http://192.168.1.x:8012/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Firebase Auth - Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ============================================================================
# EXTERNAL API KEYS (Optional - for ETL services)
# ============================================================================
# Crunchbase - Get from: https://data.crunchbase.com/
CRUNCHBASE_API_KEY=your_crunchbase_api_key

# Clearbit - Get from: https://dashboard.clearbit.com/
CLEARBIT_API_KEY=your_clearbit_api_key

# Plaid - Get from: https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENVIRONMENT=sandbox

# ============================================================================
# ML CONFIGURATION
# ============================================================================
ML_ENABLED=false
EMBEDDING_MODEL=all-MiniLM-L6-v2

# MinIO Configuration (Default) - use localhost:9000 for local dev without Docker network
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vc-matcher

# Docker Compose / production (set in backend/.env on server)
POSTGRES_PASSWORD=your_postgres_password
REDIS_PASSWORD=your_redis_password
MINIO_ROOT_PASSWORD=your_minio_password

# Or AWS S3 (Alternative)

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=VC-Startup-Matching
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:3000

# Due Diligence APIs (all have free tiers)
APOLLO_API_KEY=your_apollo_api_key
HUNTER_API_KEY=your_hunter_api_key
OPENAI_API_KEY=your_openai_api_key
PDL_API_KEY=your_pdl_api_key
